{% extends 'base.html.twig' %}

{% block title %}Connexion - Stubborn Boutique{% endblock %}

{# Bloc pour ajouter le CSS spécifique à la page login #}
{% block stylesheets %}
    {{ parent() }} {# conserve style.css pour le layout #}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}"> {# CSS spécifique au formulaire #}
{% endblock %}

{% block content %}

<div class="form-container">
    <h1>Se connecter</h1>

    {% if error %}
        <div>
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form method="post" action="{{ path('login') }}">
        <label for="inputEmail">Email :</label>
        <input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" autofocus>

        <label for="inputPassword">Mot de passe :</label>
        <input type="password" name="password" id="inputPassword" autocomplete="current-password" required>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="submit-wrapper">
            <button type="submit">Se connecter</button>

            <div class="forgot-password-wrapper">
                <a href="#" class="forgot-password-link">Mot de passe oublié</a>
            </div>
        </div>

    <div class="login-link-wrapper">
        <p>Pas encore inscrit ?</p>
        <button type="button" onclick="window.location.href='{{ path('app_register') }}'" class="form-button">
        Créer un compte
    </button>
    </div>


<div class="home-link-wrapper">
    <a href="{{ path('home') }}" class="home-link">Retour à l'accueil</a>
</div>

</form>
</div>
{% endblock %}
