<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Stubborn Boutique{% endblock %}</title>

    
    {% block stylesheets %}
        <!-- CSS principal -->
        <link rel="stylesheet" href="{{ asset('styles/style.css') }}">
        <!-- CSS du composant product card -->
    <link rel="stylesheet" href="{{ asset('styles/productCard.css') }}">
    {% endblock %}

    {# JS / importmap #}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body>
    
    <header class="site-header">
    
    <div class="logo">
    <a href="{{ path('home') }}">
        <img src="{{ asset('images/logo.png') }}" alt="Stubborn Logo">
    </a>
    <p class="logo-tagline">Don't compromise on your look</p>
</div>

    <nav class="main-nav">
        <ul class="main-menu">
    <li>
        <a href="{{ path('home') }}"
           class="{{ app.request.attributes.get('_route') == 'home' ? 'active' : '' }}">
           Accueil
        </a>
    </li>

    {% if app.user %}
        <li>
            <a href="{{ path('product_list') }}"
                class="{{ app.request.attributes.get('_route') == 'product_list' ? 'active' : '' }}">
                Boutique
            </a>
        </li>
        <li>
            <a href="{{ path('cart_show') }}"
                class="{{ app.request.attributes.get('_route') == 'cart_show' ? 'active' : '' }}">
                Panier
            </a>
        </li>
        {% if is_granted('ROLE_ADMIN') %}
                <li>
                    <a href="{{ path('app_admin') }}"
                       class="{{ app.request.attributes.get('_route') == 'app_admin' ? 'active' : '' }}">
                       Back-office
                    </a>
                </li>
            {% endif %}
        <li>
            <a href="{{ path('logout') }}"
               class="{{ app.request.attributes.get('_route') == 'logout' ? 'active' : '' }}">
               Se déconnecter
            </a>
        </li>
    {% else %}
        <li>
            <a href="{{ path('app_register') }}"
               class="{{ app.request.attributes.get('_route') == 'app_register' ? 'active' : '' }}">
               S’inscrire
            </a>
        </li>
        <li>
            <a href="{{ path('login') }}"
               class="{{ app.request.attributes.get('_route') == 'login' ? 'active' : '' }}">
               Se connecter
            </a>
        </li>
    {% endif %}
</ul>
        </ul>
    </nav>

</header>


    {# CONTENU PRINCIPAL #}
    <main class="site-content">
        {% block content %}{% endblock %}
    </main>

    {# FOOTER #}
    <footer class="site-footer">
    <div class="footer-container">
        
        <!-- Colonne 1 -->
        <div class="footer-column">
            <h2>Stubborn</h2>
            <p>Don't compromise on your look</p>
        </div>

        <!-- Colonne 2 -->
        <div class="footer-column">
            <p><strong>Adresse :</strong><br>
            Piccadilly Circus, London W1J 0DA, Royaume-Uni</p>

            <p><strong>Contact :</strong><br>
            stubborn@blabla.com</p>
        </div>

    </div>
</footer>
</body>
</html>
