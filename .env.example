# --------------------------------------------------
# Configuration générale de l'application Stubborn
# --------------------------------------------------

# Environnement : dev / prod (ici dev pour le TP)
APP_ENV=dev

# Secret de l'application : nécessaire pour Symfony, valeur arbitraire en dev
APP_SECRET=change_me

# Répertoire partagé pour stocker certains fichiers (utile si utilisé)
APP_SHARE_DIR=var/share

# URL de base de l'application
DEFAULT_URI=http://localhost

# --------------------------------------------------
# Base de données
# --------------------------------------------------

# URL de connexion à MySQL
# Format : mysql://user:password@host:port/dbname?serverVersion=X&charset=utf8mb4
# Adaptez user/password selon votre config MySQL locale
DATABASE_URL="mysql://root:root@127.0.0.1:3306/stubborn_db?serverVersion=8.0&charset=utf8mb4"

# --------------------------------------------------
# Messenger / Asynchrone
# --------------------------------------------------

# DSN du transport des messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# --------------------------------------------------
# Mailer
# --------------------------------------------------

# Mailer désactivé volontairement, aucun email ne sera envoyé dans ce TP
MAILER_DSN=null://null

# --------------------------------------------------
# Stripe (paiement)
# --------------------------------------------------

# Clés de test Stripe pour achats fictifs
# Mode sandbox uniquement, aucune opération réelle
STRIPE_SECRET_KEY=copier ici la clée sk test transmise dans le rendu du devoir
STRIPE_PUBLISHABLE_KEY=copier ici la clée pk test transmise dans le rendu du devoir

# --------------------------------------------------
# Tests unitaires
# --------------------------------------------------

# KERNEL_CLASS peut rester facultatif, utilisé par PHPUnit si besoin
# Les tests s'exécutent automatiquement via script